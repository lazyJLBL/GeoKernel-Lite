{
  "cases": [
    {"name": "convex_empty", "algorithm": "convex_hull", "description": "Empty point set.", "input": {"points": []}, "expected": {"hull_size": 0}, "tags": ["degenerate"]},
    {"name": "convex_single_point", "algorithm": "convex_hull", "description": "Single point hull.", "input": {"points": [[0, 0]]}, "expected": {"hull_size": 1}, "tags": ["degenerate"]},
    {"name": "convex_two_points", "algorithm": "convex_hull", "description": "Two point hull.", "input": {"points": [[0, 0], [1, 1]]}, "expected": {"hull_size": 2}, "tags": ["degenerate"]},
    {"name": "convex_duplicates", "algorithm": "convex_hull", "description": "Duplicate points are removed.", "input": {"points": [[0, 0], [1, 0], [1, 0], [0, 1], [0, 0]]}, "expected": {"hull_size": 3}, "tags": ["duplicate"]},
    {"name": "convex_all_collinear_drop", "algorithm": "convex_hull", "description": "All collinear points collapse to endpoints.", "input": {"points": [[0, 0], [1, 0], [2, 0], [3, 0]], "keep_collinear": false}, "expected": {"hull_size": 2, "warning": "all_points_collinear"}, "tags": ["collinear"]},
    {"name": "convex_all_collinear_keep", "algorithm": "convex_hull", "description": "All collinear points are retained when requested.", "input": {"points": [[0, 0], [1, 0], [2, 0], [3, 0]], "keep_collinear": true}, "expected": {"hull_size": 4}, "tags": ["collinear"]},
    {"name": "convex_square_with_inner", "algorithm": "convex_hull", "description": "Interior points are removed.", "input": {"points": [[0, 0], [2, 0], [2, 2], [0, 2], [1, 1]]}, "expected": {"area": 4}, "tags": ["normal"]},

    {"name": "calipers_rectangle", "algorithm": "rotating_calipers", "description": "Axis-aligned rectangle diameter and bounding box.", "input": {"points": [[0, 0], [2, 0], [2, 1], [0, 1]]}, "expected": {"area": 2}, "tags": ["normal"]},
    {"name": "calipers_single", "algorithm": "rotating_calipers", "description": "Single point has zero rectangle area.", "input": {"points": [[0, 0]]}, "expected": {"area": 0}, "tags": ["degenerate"]},
    {"name": "calipers_two_points", "algorithm": "rotating_calipers", "description": "Two points form zero-area rectangle.", "input": {"points": [[0, 0], [3, 4]]}, "expected": {"diameter": 5}, "tags": ["degenerate"]},
    {"name": "calipers_triangle", "algorithm": "rotating_calipers", "description": "Triangle hull has nonzero minimum rectangle.", "input": {"points": [[0, 0], [3, 0], [1, 2]]}, "expected": {"hull_size": 3}, "tags": ["normal"]},
    {"name": "calipers_rotated", "algorithm": "rotating_calipers", "description": "Rotated diamond tests angle handling.", "input": {"points": [[0, 1], [1, 0], [2, 1], [1, 2]]}, "expected": {"hull_size": 4}, "tags": ["rotation"]},
    {"name": "calipers_with_duplicates", "algorithm": "rotating_calipers", "description": "Duplicate points do not affect hull.", "input": {"points": [[0, 0], [1, 0], [1, 1], [0, 1], [1, 1]]}, "expected": {"hull_size": 4}, "tags": ["duplicate"]},
    {"name": "calipers_wide_cloud", "algorithm": "rotating_calipers", "description": "Point cloud with interior noise.", "input": {"points": [[-2, 0], [3, 0], [2, 2], [-1, 3], [0, 1], [1, 1]]}, "expected": {"hull_size": 4}, "tags": ["normal"]},

    {"name": "segment_cross", "algorithm": "segment_intersection", "description": "Two segments cross in their interiors.", "input": {"segments": [[[0, 0], [2, 2]], [[0, 2], [2, 0]]]}, "expected": {"pairs": 1, "type": "point"}, "tags": ["cross"]},
    {"name": "segment_endpoint_touch", "algorithm": "segment_intersection", "description": "Two segments touch at one endpoint.", "input": {"segments": [[[0, 0], [1, 1]], [[1, 1], [2, 0]]]}, "expected": {"type": "point"}, "tags": ["endpoint"]},
    {"name": "segment_partial_overlap", "algorithm": "segment_intersection", "description": "Collinear segments partially overlap.", "input": {"segments": [[[0, 0], [4, 0]], [[2, 0], [6, 0]]]}, "expected": {"type": "overlap"}, "tags": ["overlap", "collinear"]},
    {"name": "segment_full_overlap", "algorithm": "segment_intersection", "description": "Identical collinear segments overlap completely.", "input": {"segments": [[[0, 0], [4, 0]], [[0, 0], [4, 0]]]}, "expected": {"type": "overlap"}, "tags": ["overlap"]},
    {"name": "segment_parallel_disjoint", "algorithm": "segment_intersection", "description": "Parallel non-overlapping segments.", "input": {"segments": [[[0, 0], [1, 0]], [[0, 1], [1, 1]]]}, "expected": {"pairs": 0}, "tags": ["parallel"]},
    {"name": "segment_zero_length_on_segment", "algorithm": "segment_intersection", "description": "A zero-length segment lies on another segment.", "input": {"segments": [[[1, 0], [1, 0]], [[0, 0], [2, 0]]]}, "expected": {"type": "point"}, "tags": ["zero_length"]},
    {"name": "segment_nearly_collinear", "algorithm": "segment_intersection", "description": "Near-collinear endpoints are classified with EPS.", "input": {"predicate_mode": "eps", "segments": [[[0, 0], [2, 0]], [[1, 0.0000000001], [3, 0.0000000001]]]}, "expected": {"type": "overlap"}, "tags": ["precision"]},
    {"name": "segment_nearly_collinear_filtered_exact", "algorithm": "segment_intersection", "description": "Filtered exact predicates do not collapse separated near-parallel segments.", "input": {"predicate_mode": "filtered_exact", "segments": [[[0, 0], [2, 0]], [[1, 0.0000000001], [3, 0.0000000001]]]}, "expected": {"pairs": 0}, "tags": ["precision", "predicate"]},

    {"name": "halfplane_unit_square", "algorithm": "half_plane_intersection", "description": "Four half-planes form a unit square.", "input": {"bounding_limit": 10, "halfplanes": [{"p": [0, 0], "dir": [1, 0]}, {"p": [1, 0], "dir": [0, 1]}, {"p": [1, 1], "dir": [-1, 0]}, {"p": [0, 1], "dir": [0, -1]}]}, "expected": {"status": "bounded_polygon", "area": 1}, "tags": ["bounded"]},
    {"name": "halfplane_empty_opposite", "algorithm": "half_plane_intersection", "description": "Opposite half-planes have empty intersection.", "input": {"bounding_limit": 10, "halfplanes": [{"p": [0, 0], "dir": [1, 0]}, {"p": [0, -1], "dir": [-1, 0]}]}, "expected": {"status": "empty"}, "tags": ["empty"]},
    {"name": "halfplane_unbounded_strip", "algorithm": "half_plane_intersection", "description": "A strip is clipped by the visualization bounding box.", "input": {"bounding_limit": 5, "halfplanes": [{"p": [0, 0], "dir": [1, 0]}, {"p": [1, 0], "dir": [-1, 0]}]}, "expected": {"status": "unbounded"}, "tags": ["unbounded"]},
    {"name": "halfplane_triangle", "algorithm": "half_plane_intersection", "description": "Three half-planes form a triangle.", "input": {"bounding_limit": 10, "halfplanes": [{"p": [0, 0], "dir": [2, 0]}, {"p": [2, 0], "dir": [-1, 2]}, {"p": [0, 2], "dir": [-1, -2]}]}, "expected": {"status": "bounded_polygon"}, "tags": ["bounded"]},
    {"name": "halfplane_duplicate", "algorithm": "half_plane_intersection", "description": "Duplicate half-planes do not change the result.", "input": {"bounding_limit": 10, "halfplanes": [{"p": [0, 0], "dir": [1, 0]}, {"p": [0, 0], "dir": [1, 0]}, {"p": [1, 0], "dir": [0, 1]}, {"p": [1, 1], "dir": [-1, 0]}, {"p": [0, 1], "dir": [0, -1]}]}, "expected": {"status": "bounded_polygon"}, "tags": ["duplicate"]},
    {"name": "halfplane_large_box", "algorithm": "half_plane_intersection", "description": "Large-coordinate half-planes stay stable.", "input": {"bounding_limit": 1000000, "halfplanes": [{"p": [-100, -100], "dir": [200, 0]}, {"p": [100, -100], "dir": [0, 200]}, {"p": [100, 100], "dir": [-200, 0]}, {"p": [-100, 100], "dir": [0, -200]}]}, "expected": {"status": "bounded_polygon"}, "tags": ["large_coordinate"]},
    {"name": "halfplane_degenerate_line", "algorithm": "half_plane_intersection", "description": "Parallel opposite boundaries can collapse the area.", "input": {"bounding_limit": 10, "halfplanes": [{"p": [0, 0], "dir": [1, 0]}, {"p": [0, 0], "dir": [-1, 0]}]}, "expected": {"status": "degenerate"}, "tags": ["degenerate"]},

    {"name": "clip_inside", "algorithm": "polygon_clipping", "description": "Subject polygon lies fully inside clipper.", "input": {"subject": [[0.2, 0.2], [0.8, 0.2], [0.8, 0.8], [0.2, 0.8]], "clipper": [[0, 0], [1, 0], [1, 1], [0, 1]]}, "expected": {"status": "polygon"}, "tags": ["inside"]},
    {"name": "clip_outside", "algorithm": "polygon_clipping", "description": "Subject polygon lies outside clipper.", "input": {"subject": [[2, 2], [3, 2], [3, 3], [2, 3]], "clipper": [[0, 0], [1, 0], [1, 1], [0, 1]]}, "expected": {"status": "empty"}, "tags": ["empty"]},
    {"name": "clip_partial", "algorithm": "polygon_clipping", "description": "Subject partially overlaps clipper.", "input": {"subject": [[-1, -1], [2, -1], [2, 2], [-1, 2]], "clipper": [[0, 0], [1, 0], [1, 1], [0, 1]]}, "expected": {"status": "polygon", "area": 1}, "tags": ["partial"]},
    {"name": "clip_vertex_on_edge", "algorithm": "polygon_clipping", "description": "Subject vertex lies on clipper edge.", "input": {"subject": [[0, 0.5], [0.5, 0], [1.5, 0.5], [0.5, 1.5]], "clipper": [[0, 0], [1, 0], [1, 1], [0, 1]]}, "expected": {"status": "polygon"}, "tags": ["boundary"]},
    {"name": "clip_shared_edge", "algorithm": "polygon_clipping", "description": "Subject edge overlaps clipper edge.", "input": {"subject": [[0, 0], [2, 0], [2, 1], [0, 1]], "clipper": [[0, 0], [1, 0], [1, 1], [0, 1]]}, "expected": {"status": "polygon"}, "tags": ["overlap"]},
    {"name": "clip_degenerate_line", "algorithm": "polygon_clipping", "description": "Clipping can collapse result to a line.", "input": {"subject": [[0, 0], [2, 0], [2, 0.0000000001], [0, 0.0000000001]], "clipper": [[0, 0], [1, 0], [1, 1], [0, 1]]}, "expected": {"status": "degenerate"}, "tags": ["degenerate"]},
    {"name": "clip_concave_subject", "algorithm": "polygon_clipping", "description": "Concave subject with convex clipper.", "input": {"subject": [[0, 0], [3, 0], [3, 1], [1, 1], [1, 3], [0, 3]], "clipper": [[0.5, 0.5], [2, 0.5], [2, 2], [0.5, 2]]}, "expected": {"status": "polygon"}, "tags": ["concave"]},

    {"name": "closest_two_points", "algorithm": "closest_pair", "description": "Two points define the closest pair.", "input": {"points": [[0, 0], [3, 4]]}, "expected": {"distance": 5}, "tags": ["basic"]},
    {"name": "closest_duplicate", "algorithm": "closest_pair", "description": "Duplicate points yield zero distance.", "input": {"points": [[0, 0], [1, 1], [0, 0]]}, "expected": {"distance": 0}, "tags": ["duplicate"]},
    {"name": "closest_small_distance", "algorithm": "closest_pair", "description": "Tiny distance remains representable.", "input": {"points": [[0, 0], [0.000001, 0], [1, 1]]}, "expected": {"distance": 0.000001}, "tags": ["precision"]},
    {"name": "closest_large_coordinates", "algorithm": "closest_pair", "description": "Large coordinates keep distance stable.", "input": {"points": [[1000000, 1000000], [1000001, 1000000], [0, 0]]}, "expected": {"distance": 1}, "tags": ["large_coordinate"]},
    {"name": "closest_grid", "algorithm": "closest_pair", "description": "Grid points have unit closest distance.", "input": {"points": [[0, 0], [0, 1], [1, 0], [1, 1]]}, "expected": {"distance": 1}, "tags": ["normal"]},
    {"name": "closest_negative", "algorithm": "closest_pair", "description": "Negative coordinates are supported.", "input": {"points": [[-2, -2], [-1.9, -2], [4, 4]]}, "expected": {"distance": 0.1}, "tags": ["normal"]},
    {"name": "closest_insufficient", "algorithm": "closest_pair", "description": "One point cannot form a pair.", "input": {"points": [[0, 0]]}, "expected": {"valid": false}, "tags": ["degenerate"]},

    {"name": "triangulate_triangle", "algorithm": "triangulation", "description": "Triangle input returns one triangle.", "input": {"polygon": [[0, 0], [1, 0], [0, 1]]}, "expected": {"triangles": 1}, "tags": ["basic"]},
    {"name": "triangulate_square", "algorithm": "triangulation", "description": "Square returns two triangles.", "input": {"polygon": [[0, 0], [1, 0], [1, 1], [0, 1]]}, "expected": {"triangles": 2}, "tags": ["convex"]},
    {"name": "triangulate_concave_l", "algorithm": "triangulation", "description": "Concave L shape triangulates by ear clipping.", "input": {"polygon": [[0, 0], [3, 0], [3, 1], [1, 1], [1, 3], [0, 3]]}, "expected": {"valid": true}, "tags": ["concave"]},
    {"name": "triangulate_clockwise", "algorithm": "triangulation", "description": "Clockwise input is normalized.", "input": {"polygon": [[0, 0], [0, 1], [1, 1], [1, 0]]}, "expected": {"valid": true}, "tags": ["orientation"]},
    {"name": "triangulate_repeated_vertex", "algorithm": "triangulation", "description": "Repeated adjacent vertex is removed.", "input": {"polygon": [[0, 0], [1, 0], [1, 0], [1, 1], [0, 1]]}, "expected": {"valid": true}, "tags": ["duplicate"]},
    {"name": "triangulate_collinear_vertex", "algorithm": "triangulation", "description": "Collinear middle vertex is removed.", "input": {"polygon": [[0, 0], [0.5, 0], [1, 0], [1, 1], [0, 1]]}, "expected": {"valid": true}, "tags": ["collinear"]},
    {"name": "triangulate_self_intersect", "algorithm": "triangulation", "description": "Self-intersecting polygon is rejected.", "input": {"polygon": [[0, 0], [1, 1], [0, 1], [1, 0]]}, "expected": {"valid": false}, "tags": ["invalid"]},

    {"name": "delaunay_triangle", "algorithm": "delaunay", "description": "Three points produce one experimental triangle.", "input": {"points": [[0, 0], [1, 0], [0, 1]]}, "expected": {"experimental": true}, "tags": ["experimental"]},
    {"name": "delaunay_square", "algorithm": "delaunay", "description": "Four square points produce a diagonal triangulation.", "input": {"points": [[0, 0], [1, 0], [1, 1], [0, 1]]}, "expected": {"experimental": true}, "tags": ["experimental"]},
    {"name": "delaunay_duplicate_points", "algorithm": "delaunay", "description": "Duplicate points are removed before triangulation.", "input": {"points": [[0, 0], [1, 0], [0, 1], [0, 1]]}, "expected": {"experimental": true}, "tags": ["duplicate", "experimental"]},
    {"name": "delaunay_five_points", "algorithm": "delaunay", "description": "Interior point creates multiple triangles.", "input": {"points": [[0, 0], [2, 0], [2, 2], [0, 2], [1, 1]]}, "expected": {"experimental": true}, "tags": ["experimental"]},
    {"name": "delaunay_collinear", "algorithm": "delaunay", "description": "Collinear set is an experimental degenerate case.", "input": {"points": [[0, 0], [1, 0], [2, 0], [3, 0]]}, "expected": {"experimental": true}, "tags": ["collinear", "experimental"]},
    {"name": "delaunay_large_coordinates", "algorithm": "delaunay", "description": "Large coordinates are accepted by Bowyer-Watson implementation.", "input": {"points": [[1000, 1000], [1001, 1000], [1000, 1001], [1002, 1002]]}, "expected": {"experimental": true}, "tags": ["large_coordinate", "experimental"]},
    {"name": "delaunay_random_cloud", "algorithm": "delaunay", "description": "Small non-degenerate random cloud.", "input": {"points": [[0.1, 0.2], [0.9, 0.1], [0.3, 0.8], [0.7, 0.6], [0.4, 0.4], [0.2, 0.5]]}, "expected": {"experimental": true}, "tags": ["experimental", "normal"]}
  ]
}
